<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_heading"
            android:textColor="@color/echo_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/app_intro"
            android:textColor="@color/echo_muted"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="@string/folder_heading"
            android:textColor="@color/echo_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/folder_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/folder_not_selected"
            android:textColor="@color/echo_muted"
            android:textSize="15sp" />

        <Button
            android:id="@+id/choose_folder_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/choose_folder" />

        <TextView
            android:id="@+id/recording_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:text="@string/status_ready"
            android:textColor="@color/echo_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/record_button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="14dp"
            android:text="@string/record"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pending_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/pending_count"
            android:textColor="@color/echo_muted"
            android:textSize="14sp" />

        <Button
            android:id="@+id/retry_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/retry_uploads" />

        <Button
            android:id="@+id/add_widget_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="@string/add_widget" />
    </LinearLayout>
</ScrollView>
